{
	"schemaVersion": "0.1.0",
	"name": "Default",
	"behavior": "create",
	"noteContentFormat": "{{content}}",
	"properties": [
		{
			"name": "author",
			"value": "{{author|split:\\\", \\\"|wikilink|join}}",
			"type": "multitext"
		},
		{
			"name": "source",
			"value": "web",
			"type": "text"
		},
		{
			"name": "url",
			"value": "{{url}}",
			"type": "text"
		},
		{
			"name": "saved",
			"value": "{{date}}",
			"type": "text"
		},
		{
			"name": "tags",
			"value": "article",
			"type": "multitext"
		},
		{
			"name": "published",
			"value": "{{published}}",
			"type": "date"
		},
		{
			"name": "description",
			"value": "{{description}}",
			"type": "text"
		},
		{
			"name": "id",
			"value": "{{title}}",
			"type": "text"
		},
		{
			"name": "annotation",
			"value": "full article",
			"type": "text"
		}
	],
	"triggers": [],
	"noteNameFormat": "{{title}}",
	"path": "01_raw/_inbox/文章"
}